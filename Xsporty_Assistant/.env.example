PORT=8787

# Xsporty Assistant channel settings
XSPORTY_ASSISTANT_VERIFY_TOKEN=change-this-local-verify-token
XSPORTY_ASSISTANT_ACCESS_TOKEN=
XSPORTY_ASSISTANT_CHANNEL_ID=
XSPORTY_ASSISTANT_APP_SECRET=
XSPORTY_ASSISTANT_API_VERSION=v1

# xSporty links and backend
# Leave blank until the frontend is deployed.
SITE_URL=
MARKET_API_BASE_URL=http://127.0.0.1:3000

# Optional sports data API.
# Use this if you want the assistant to answer current World Cup fixtures, live scores,
# groups, and schedules even before those are exposed by the xSporty backend.
SPORTS_API_PROVIDER=api-football
SPORTS_API_BASE_URL=https://v3.football.api-sports.io
SPORTS_API_KEY=

# If your key is from RapidAPI instead of API-SPORTS direct, set the host too.
# SPORTS_API_BASE_URL=https://api-football-v1.p.rapidapi.com/v3
# SPORTS_API_HOST=api-football-v1.p.rapidapi.com

FOOTBALL_WORLD_CUP_LEAGUE_ID=1
FOOTBALL_WORLD_CUP_SEASON=2026

# Compliance links
TERMS_URL=
PRIVACY_URL=
SUPPORT_URL=
